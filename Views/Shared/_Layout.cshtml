<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - FindYourMain</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <nav class="navbar navbar-expand-sm">

        <div class="container">

            <a class="navbar-brand"
               asp-controller="Home"
               asp-action="Index">
                FindYourMain
            </a>

            <div>

                <a class="nav-link d-inline"
                   asp-controller="Home"
                   asp-action="Index">
                    Home
                </a>

                <a class="nav-link d-inline"
                   asp-controller="Character"
                   asp-action="Generate">
                    Generate
                </a>

                <a class="nav-link d-inline"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    Dashboard
                </a>

                <a class="nav-link d-inline"
                   asp-controller="Statistics"
                   asp-action="Create">
                    Statistics
                </a>

                <a class="nav-link d-inline"
                   asp-controller="Admin"
                   asp-action="Index">
                    Admin
                </a>

            </div>

        </div>

    </nav>

    <div class="container">

        @RenderBody()

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>