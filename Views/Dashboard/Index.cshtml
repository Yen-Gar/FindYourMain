@model List<FindYourMain.Models.Stats>

<h1>Dashboard</h1>

@if (ViewBag.BestCharacter != null)
{
    <div class="best-character">
        <h2>🏆 Best Character</h2>
        <p>Character ID: @ViewBag.BestCharacter.CharacterID</p>
        <p>Kills: @ViewBag.BestCharacter.TotalKills</p>
        <p>Damage: @ViewBag.BestCharacter.TotalDamage</p>
        <p>Assists: @ViewBag.BestCharacter.TotalAssists</p>
    </div>
}

<div class="card-box">

    <table>
        <tr>
            <th>Kills</th>
            <th>Assists</th>
            <th>Damage</th>
            <th>Date</th>
        </tr>

        @foreach (var stat in Model)
        {
            <tr>
                <td>@stat.Kills</td>
                <td>@stat.Assists</td>
                <td>@stat.Damage</td>
                <td>@stat.Date</td>
            </tr>
        }

    </table>

</div>